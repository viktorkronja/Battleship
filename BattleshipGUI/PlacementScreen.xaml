<UserControl x:Class="BattleshipGUI.PlacementScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource CrtBgBrush}"
             Focusable="True" KeyDown="OnKeyDown">
    <DockPanel Margin="8">
        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource CrtDimBrush}"
                BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
            <Grid>
                <TextBlock Text="// DEPLOY FLEET" Style="{StaticResource CrtText}"
                           FontSize="14" HorizontalAlignment="Left"/>
                <TextBlock Text="STEP 1 OF 2" Style="{StaticResource CrtTextDim}"
                           FontSize="10" HorizontalAlignment="Center"/>
                <TextBlock x:Name="RotationLabel" Style="{StaticResource CrtText}"
                           FontSize="10" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border x:Name="BoardHost"/>
                <TextBlock x:Name="StatusText" Style="{StaticResource CrtTextDim}"
                           FontSize="12" Margin="0,12,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border BorderBrush="{StaticResource CrtDimBrush}" BorderThickness="1" Padding="8">
                    <StackPanel>
                        <TextBlock Text="▌ SHIP DOCK" Style="{StaticResource CrtText}" FontSize="12" Margin="0,0,0,8"/>
                        <StackPanel x:Name="ShipDock"/>
                    </StackPanel>
                </Border>

                <Button Content="↻ AUTO REDEPLOY" Style="{StaticResource CrtButton}"
                        Margin="0,16,0,0" Click="AutoDeploy_Click"/>
                <Button Content="✕ CLEAR ALL" Style="{StaticResource CrtButton}"
                        Margin="0,8,0,0" Click="ClearAll_Click"/>
                <Button x:Name="RotateButton" Style="{StaticResource CrtButton}"
                        Margin="0,8,0,0" Click="Rotate_Click"/>
                <Button x:Name="CommenceButton" Content="▶ COMMENCE BATTLE"
                        Style="{StaticResource CrtButton}" Margin="0,16,0,0"
                        Click="Commence_Click" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
